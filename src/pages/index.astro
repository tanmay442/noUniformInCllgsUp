                <path d="M46 37 L54 37 L60 85 L50 95 L40 85 Z" fill="oklch(0.2 0.015 305)" stroke="oklch(0.85 0.01 90)" stroke-width="2" stroke-linejoin="round"/>
                <path d="M50 37 V93" stroke="oklch(0.44 0.015 305)" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
                <path d="M45 45 L50 50" stroke="oklch(0.44 0.015 305)" stroke-width="1.5" stroke-linecap="round" opacity="0.3"/>
                <path d="M55 55 L50 60" stroke="oklch(0.44 0.015 305)" stroke-width="1.5" stroke-linecap="round" opacity="0.3"/>
