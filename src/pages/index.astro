      }

      @media (max-width: 640px) {
        .lb-row,
        .lb-header {
          grid-template-columns: 44px minmax(0, 1fr) 62px;
        }

        .lb-cell {
          padding: 0.6rem 0.5rem;
        }

        .lb-name {
          font-size: 0.82rem;
        }

        .lb-rank {
          font-size: 0.82rem;
        }

