          <div class="share-actions">
            <button id="download-card" type="button">Download and Share</button>
            <a id="share-instagram" class="share-link" href="#">Instagram</a>
            <a id="share-x" class="share-link" href="#" target="_blank" rel="noreferrer">X</a>
          </div>
        </div>
      </div>

      <div class="template-grid">
        <article class="template">
          <h4>Pre-written X template</h4>
          <pre id="x-template"></pre>
          <button type="button" data-copy-target="x-template">Copy X text</button>
        </article>

        <article class="template">
          <h4>Instagram caption</h4>
          <pre id="ig-template"></pre>
          <button type="button" data-copy-target="ig-template">Copy caption</button>
        </article>
