      <p>
        One vote per device. No email, no phone, no tracking. Just a clear public signal
        that adult students reject this regressive policy.
      </p>
      <ul class="hashtag-list" aria-label="Official hashtags">
        <li>#NoToUPCollegeUniform</li>
        <li>#MyCampusMyChoice</li>
        <li>#AdultsNotKids</li>
      </ul>
    </div>

    <div class="vote-shell" id="vote-shell">
      <form id="vote-form" novalidate>
        <div class="field">
          <label for="institution-search">Select your institution to register your dissent.</label>
          <div class="combobox">
            <input
              id="institution-search"
              type="text"
              autocomplete="off"
              role="combobox"
              aria-autocomplete="list"
              aria-expanded="false"
              aria-controls="institution-results"
              placeholder="Type your college or university name..."
            />
            <input id="college-id" type="hidden" />
            <ul id="institution-results" class="result-list hidden" role="listbox"></ul>
          </div>
          <p class="field-hint" id="institution-hint">Start typing to filter colleges, or choose Other if not listed.</p>
        </div>

        <div class="field">
          <label>Human verification</label>
          <div class="turnstile-wrap" id="turnstile-widget"></div>
          <p class="field-hint">No email. No phone number. One verified vote per device.</p>
        </div>

        <input id="website" class="honey" tabindex="-1" autocomplete="off" />

        <button id="submit-btn" type="submit" disabled>Cast My Vote</button>
        <p class="vote-message" id="vote-message" aria-live="polite"></p>
      </form>

      <div class="vote-success hidden" id="vote-success" aria-live="polite">
        <p class="title">Vote registered. The tally grows.</p>
        <p class="copy">Now push this to your hostel and class groups.</p>
      </div>
    </div>
  </div>

  <div class="shell">
